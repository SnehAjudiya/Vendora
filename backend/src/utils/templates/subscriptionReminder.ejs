<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Subscription Reminder</title>
  </head>
  <body>
    <div>
      <h2>Subscription Renewal Reminder</h2>

      <p>Hi <strong><%= user.fullName %></strong>,</p>

      <p>This is a reminder that your subscription will renew soon.</p>

      <hr />

      <h3>Subscription Details</h3>

      <p><strong>Plan:</strong> <%= subscription.name %></p>
      <p><strong>Amount:</strong> ₹<%= subscription.amount / 100 %></p>
      <p>
        <strong>Billing Interval:</strong> Every <%= subscription.interval_count
        %> <%= subscription.interval %>(s)
      </p>

      <% const renewalDate = new Date(subscription.updatedAt);
      renewalDate.setDate(renewalDate.getDate() + subscription.interval_count);
      %>

      <p>
        <strong>Next Renewal Date:</strong> <%= renewalDate.toLocaleString() %>
      </p>

      <hr />

      <p>
        If you wish to make any changes or cancel your subscription, please do
        so before the renewal time to avoid charges.
      </p>

      <p>
        Regards,<br />
        <strong>Your Team</strong>
      </p>
    </div>
  </body>
</html>
